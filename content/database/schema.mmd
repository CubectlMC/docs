erDiagram
    IDENTITY_USERS ||--o{ IDENTITY_USER_ROLES : has
    IDENTITY_ROLES ||--o{ IDENTITY_USER_ROLES : assigned
    IDENTITY_ROLES ||--o{ IDENTITY_ROLE_PERMISSIONS : has
    IDENTITY_PERMISSIONS ||--o{ IDENTITY_ROLE_PERMISSIONS : grants
    IDENTITY_USERS ||--o{ IDENTITY_REFRESH_TOKENS : owns

    INSTANCE_INSTANCES ||--|| INSTANCE_RESOURCES : has
    INSTANCE_INSTANCES ||--|| INSTANCE_NETWORKS : has
    INSTANCE_INSTANCES ||--|| INSTANCE_STORAGE : has
    INSTANCE_INSTANCES ||--o| INSTANCE_DOCKER_CONTAINERS : has
    INSTANCE_INSTANCES ||--o{ INSTANCE_DNS_RECORDS : has
    INSTANCE_INSTANCES ||--o{ INSTANCE_MEMBERS : has
    INSTANCE_INSTANCES ||--o{ INSTANCE_CONTENT : selects
    INSTANCE_INSTANCES ||--o{ INSTANCE_EVENTS : emits

    FILE_CONTENT_PROVIDERS ||--o{ FILE_CONTENT_PROJECTS : owns
    FILE_CONTENT_PROJECTS ||--o{ FILE_CONTENT_VERSIONS : has
    FILE_CONTENT_VERSIONS ||--o{ FILE_CONTENT_FILES : has
    FILE_CONTENT_VERSIONS ||--o{ FILE_CONTENT_DEPENDENCIES : requires
    FILE_CONTENT_FILES ||--o{ FILE_CONTENT_DOWNLOADS : downloaded
    FILE_CONTENT_PROVIDERS ||--o{ FILE_CONTENT_UPDATE_CHECKS : checks
    FILE_CONTENT_PROJECTS ||--o{ FILE_CONTENT_UPDATE_CHECKS : checked
    FILE_CONTENT_VERSIONS ||--o{ FILE_CONTENT_UPDATE_CHECKS : current_version
    FILE_CONTENT_UPDATE_CHECKS ||--o{ FILE_CONTENT_UPDATE_ACTIONS : creates

    INSTANCE_INSTANCES ||--o{ METRIC_INSTANCE_SNAPSHOTS : measured_by
    METRIC_COLLECTION_RUNS ||--o{ METRIC_INSTANCE_SNAPSHOTS : collects
    METRIC_COLLECTION_RUNS ||--o{ METRIC_HOST_SNAPSHOTS : collects

    IDENTITY_USERS {
        uuid id PK
        varchar username UK
        varchar password_hash
        varchar status
        timestamptz last_login_at
    }

    IDENTITY_ROLES {
        uuid id PK
        varchar code UK
        varchar display_name
        boolean system_role
    }

    IDENTITY_PERMISSIONS {
        uuid id PK
        varchar code UK
    }

    IDENTITY_USER_ROLES {
        uuid user_id PK
        uuid role_id PK
        uuid assigned_by
    }

    IDENTITY_ROLE_PERMISSIONS {
        uuid role_id PK
        uuid permission_id PK
    }

    IDENTITY_REFRESH_TOKENS {
        uuid id PK
        uuid user_id FK
        varchar token_hash UK
        timestamptz expires_at
        timestamptz revoked_at
    }

    INSTANCE_INSTANCES {
        uuid id PK
        varchar slug UK
        varchar display_name
        varchar status
        varchar health
        uuid owner_user_id
        varchar minecraft_version
        varchar loader_type
        varchar loader_version
        varchar java_version_mode
        integer resolved_java_version
        boolean restart_required
    }

    INSTANCE_RESOURCES {
        uuid instance_id PK
        integer memory_min_mb
        integer memory_max_mb
        numeric cpu_limit
    }

    INSTANCE_NETWORKS {
        uuid instance_id PK
        integer public_port UK
        integer container_port
        varchar dns_name
        varchar dns_mode
    }

    INSTANCE_STORAGE {
        uuid instance_id PK
        varchar host_data_path
        varchar container_data_path
    }

    INSTANCE_DOCKER_CONTAINERS {
        uuid id PK
        uuid instance_id FK
        varchar container_id UK
        varchar container_name UK
        varchar image
        varchar status
    }

    INSTANCE_DNS_RECORDS {
        uuid id PK
        uuid instance_id FK
        varchar provider
        varchar record_type
        varchar record_name
        varchar record_value
        varchar status
    }

    INSTANCE_MEMBERS {
        uuid instance_id PK
        uuid user_id PK
        varchar role_code
    }

    INSTANCE_CONTENT {
        uuid id PK
        uuid instance_id FK
        varchar content_type
        varchar provider_id
        varchar project_id
        varchar version_id
        uuid file_id
        boolean enabled
    }

    INSTANCE_EVENTS {
        uuid id PK
        uuid instance_id FK
        uuid actor_user_id
        varchar event_type
    }

    FILE_CONTENT_PROVIDERS {
        uuid id PK
        varchar code UK
        varchar display_name
        boolean enabled
        varchar status
    }

    FILE_CONTENT_PROJECTS {
        uuid id PK
        uuid provider_id FK
        varchar external_project_id
        varchar slug
        varchar content_type
        varchar display_name
    }

    FILE_CONTENT_VERSIONS {
        uuid id PK
        uuid project_id FK
        varchar external_version_id
        varchar version_number
        varchar release_type
        text[] minecraft_versions
        text[] loader_types
    }

    FILE_CONTENT_FILES {
        uuid id PK
        uuid version_id FK
        varchar external_file_id
        varchar file_name
        text download_url
        varchar sha1
        varchar sha512
    }

    FILE_CONTENT_DEPENDENCIES {
        uuid id PK
        uuid version_id FK
        uuid dependency_project_id
        uuid dependency_version_id
        varchar dependency_type
    }

    FILE_CONTENT_DOWNLOADS {
        uuid id PK
        uuid instance_id
        uuid content_file_id FK
        varchar target_path
        varchar status
    }

    FILE_CONTENT_UPDATE_CHECKS {
        uuid id PK
        uuid instance_id
        uuid provider_id FK
        uuid project_id FK
        uuid current_version_id FK
        uuid latest_version_id FK
        varchar status
        timestamptz checked_at
    }

    FILE_CONTENT_UPDATE_ACTIONS {
        uuid id PK
        uuid update_check_id FK
        uuid instance_id
        uuid from_version_id FK
        uuid to_version_id FK
        varchar status
    }

    METRIC_INSTANCE_SNAPSHOTS {
        uuid id PK
        uuid collection_run_id FK
        uuid instance_id
        timestamptz captured_at
        varchar container_status
        numeric cpu_percent
        integer memory_usage_mb
        integer memory_limit_mb
    }

    METRIC_HOST_SNAPSHOTS {
        uuid id PK
        uuid collection_run_id FK
        timestamptz captured_at
        numeric cpu_percent
        integer memory_total_mb
        integer memory_used_mb
        integer running_instances
    }

    METRIC_COLLECTION_RUNS {
        uuid id PK
        timestamptz started_at
        timestamptz finished_at
        varchar status
        integer instances_collected
    }
